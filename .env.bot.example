# Optional environment defaults. Copy this file to `.env.bot` and fill in only
# the values you need. The real `.env.bot` is gitignored and MUST NOT be committed.
# Bot credentials can instead be entered and saved through the dashboard.

# --- live-realm token capture (`node get-token.mjs`) ---
BOT_USER=your_account
BOT_PASS=your_password
BOT_CLASS=druid

# --- initial dashboard configuration (optional) ---
# These defaults are used only until console-config.json has been saved.
BOT_COUNT=0
SERVER_URL=https://worldofclaudecraft.com
# BOT_1_PASS=your_password
# BOT_1_NAME=ClaudebotA
# BOT_1_CLASS=warrior

# --- dashboard control token (optional; auto-generated if unset) ---
# DASH_TOKEN=choose-a-long-random-string
