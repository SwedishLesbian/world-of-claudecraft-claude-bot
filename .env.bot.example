# Template for bot credentials. Copy to `bot/.env.bot` and fill in real values.
#   cp bot/.env.bot.example bot/.env.bot
# The real bot/.env.bot is gitignored and MUST NOT be committed.

# --- solo bot ---
BOT_USER=your_account
BOT_PASS=your_password
BOT_NAME=Claudruid
BOT_CLASS=druid

# --- 5-bot fleet ---
FLEET_USER=your_fleet_prefix
FLEET_PASS=your_fleet_password

# --- dashboard auth (optional; auto-generated if unset) ---
# DASH_TOKEN=choose-a-long-random-string
